{
    "vim.leader": "<Space>",
    "vim.hlsearch": true,
    "vim.overrideCopy": true,
    "vim.smartcase": true,
    "vim.ignorecase": true,
    "vim.showmodename": true,
    "vim.handleKeys": {
        "<C-d>": true,
        "<C-c>": true,
        "<C-f>": true
    },
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<C-d>"
            ],
            "after": [
                "<C-d>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "<C-u>"
            ],
            "after": [
                "<C-u>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "leader",
                "w"
            ],
            "commands": [
                ":w"
            ]
        },
        {
            "before": [
                "leader",
                "q"
            ],
            "commands": [
                ":q"
            ]
        },
        {
            "before": [
                "leader",
                "x"
            ],
            "commands": [
                ":x"
            ]
        },
        {
            "before": [
                "[",
                "d"
            ],
            "commands": [
                "editor.action.marker.prev"
            ]
        },
        {
            "before": [
                "]",
                "d"
            ],
            "commands": [
                "editor.action.marker.next"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "a"
            ],
            "commands": [
                "editor.action.quickFix"
            ]
        },
        {
            "before": [
                "<C-p>"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "f"
            ],
            "commands": [
                "editor.action.formatDocument"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showDefinitionPreviewHover"
            ]
        },
        {
            "before": [
                "<Esc>"
            ],
            "commands": [
                ":nohlsearch"
            ]
        },
        {
            "before": [
                "<leader>",
                "y"
            ],
            "after": [
                "\"",
                "+",
                "y"
            ]
        },
        {
            "before": [
                "<leader>",
                "Y"
            ],
            "after": [
                "\"",
                "+",
                "Y"
            ]
        },
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d",
                "d"
            ]
        },
        {
            "before": [
                "<leader>",
                "x"
            ],
            "after": [
                "\"",
                "_",
                "x"
            ]
        },
        {
            "before": [
                "<leader>",
                "a"
            ],
            "commands": [
                "vscode-harpoon.addEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "e"
            ],
            "commands": [
                "vscode-harpoon.editEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "h"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor1"
            ]
        },
        {
            "before": [
                "<leader>",
                "j"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor2"
            ]
        },
        {
            "before": [
                "<leader>",
                "k"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor3"
            ]
        },
        {
            "before": [
                "<leader>",
                "l"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor4"
            ]
        },
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.revealDefinition"
            ]
        },
        {
            "before": [
                "g",
                "r"
            ],
            "commands": [
                "editor.action.referenceSearch.trigger"
            ]
        },
        {
            "before": [
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ]
        },
        {
            "before": [
                "<leader>",
                "r"
            ],
            "commands": [
                "editor.action.rename"
            ]
        },
        {
            "before": [
                "<C-t>"
            ],
            "commands": [
                "workbench.action.navigateBack"
            ]
        },
        {
            "before": [
                "<C-o>"
            ],
            "commands": [
                "workbench.action.navigateBack"
            ]
        },
        {
            "before": [
                "<C-i>"
            ],
            "commands": [
                "workbench.action.navigateForward"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "<"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },
        {
            "before": [
                ">"
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        {
            "before": [
                "J"
            ],
            "commands": [
                "editor.action.moveLinesDownAction"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.moveLinesUpAction"
            ]
        },
        {
            "before": [
                "<leader>",
                "y"
            ],
            "after": [
                "\"",
                "+",
                "y"
            ]
        },
        {
            "before": [
                "<leader>",
                "Y"
            ],
            "after": [
                "\"",
                "+",
                "Y"
            ]
        },
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d",
                "d"
            ]
        },
        {
            "before": [
                "<leader>",
                "x"
            ],
            "after": [
                "\"",
                "_",
                "x"
            ]
        }
    ],
    "update.showReleaseNotes": false,
    "window.menuBarVisibility": "toggle",
    "window.commandCenter": false,
    "explorer.compactFolders": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "breadcrumbs.enabled": true,
    "workbench.startupEditor": "none",
    "workbench.editor.showTabs": "single",
    "workbench.colorCustomizations": {
        "editorCursor.background": "#000000",
        "editorCursor.foreground": "#ffffff",
        "terminalCursor.background": "#000000",
        "terminalCursor.foreground": "#ffffff"
    },
    "terminal.integrated.fontFamily": "JetBrains Mono",
    "terminal.integrated.fontSize": 12,
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 12,
    "editor.lineHeight": 18,
    "editor.fontWeight": "normal",
    "editor.fontLigatures": true,
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": true,
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.stickyScroll.enabled": false,
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "block",
    "editor.renderLineHighlight": "none",
    "editor.bracketPairColorization.enabled": false,
    "editor.semanticHighlighting.enabled": false,
    "editor.formatOnSave": true,
    "editor.suggest.insertMode": "replace",
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.lineNumbers": "relative",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.scrollbar.horizontalScrollbarSize": 0,
    "editor.matchBrackets": "near",
    "editor.guides.indentation": false,
    "editor.folding": false,
    "editor.cursorSurroundingLines": 10,
    "git.decorations.enabled": false,
    "scm.diffDecorations": "none",
    "ActiveFileInStatusBar.fullpath": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": false,
    "zenMode.showTabs": "none",
    "chat.commandCenter.enabled": false,
    "window.customTitleBarVisibility": "never",
    "window.titleBarStyle": "native",
    "go.toolsManagement.autoUpdate": true,
    "search.exclude": {
        "**/vendor/**": true
    },
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "makefile.configureOnOpen": true,
    "debug.closeReadonlyTabsOnEnd": true,
    "debug.console.closeOnEnd": true,
    "debug.openExplorerOnEnd": true,
    "github.copilot.nextEditSuggestions.enabled": true,
    "excalidraw.theme": "dark",
    "docker.extension.dockerEngineAvailabilityPrompt": false,
    "remote.extensionKind": {
        "GitHub.copilot": [
            "ui"
        ],
        "GitHub.copilot-chat": [
            "ui"
        ]
    },
    "workbench.colorTheme": "Default Dark Modern",
    "cursor.cpp.disabledLanguages": [
        "markdown",
        "scminput"
    ],
    "symbols.hidesExplorerArrows": false,
    // golang
    "go.goroot": "/home/lucas/.gvm/gos/go1.25.0",
    "go.gopath": "/home/lucas/.gvm/pkgsets/go1.25.0/global",
    "go.lintTool": "golangci-lint-v2",
    "go.lintFlags": [
        "--enable=unused,errcheck,staticcheck,govet,misspell,gocyclo",
    ],
    // golint
    "go.lintOnSave": "workspace",
    "go.formatTool": "goimports",
    "notebook.stickyScroll.enabled": true,
    "docker.extension.enableComposeLanguageServer": false
}
